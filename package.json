{
  "name": "jobflow",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.1.3"
  },
  "scripts": {
    "verify:node": "node scripts/check-node-version.mjs",
    "dev": "pnpm verify:node && nuxt dev",
    "build": "pnpm verify:node && nuxt build",
    "preview": "pnpm verify:node && nuxt preview",
    "postinstall": "pnpm verify:node && nuxt prepare",
    "prepare": "pnpm verify:node && nuxt prepare",
    "typecheck": "pnpm verify:node && nuxt typecheck",
    "lint": "pnpm verify:node && eslint .",
    "lint:fix": "pnpm verify:node && eslint . --fix",
    "test": "pnpm verify:node && pnpm prepare && vitest",
    "test:unit": "pnpm verify:node && pnpm prepare && vitest run tests/unit --exclude tests/unit/postgres-repository.integration.test.ts --exclude tests/unit/postgres-migrations-seed.smoke.test.ts",
    "test:nuxt": "pnpm verify:node && pnpm prepare && vitest run tests/nuxt --passWithNoTests",
    "test:e2e": "pnpm verify:node && pnpm build && playwright test",
    "test:ci": "pnpm verify:node && pnpm lint && pnpm typecheck && pnpm prisma:validate && pnpm prisma:generate && pnpm test:unit && pnpm test:nuxt && pnpm db:check && pnpm test:e2e && pnpm build",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:seed": "node scripts/db/seed.mjs",
    "db:test:up": "node scripts/db/test-db-up.mjs",
    "db:test:down": "node scripts/db/test-db-down.mjs",
    "db:test:url": "node scripts/db/test-db-url.mjs",
    "db:test:reset": "pnpm db:test:down && pnpm db:test:up",
    "db:test:up:compose": "docker compose -f docker-compose.test-db.yml up -d && node scripts/db/wait-db-ready.mjs",
    "db:test:down:compose": "docker compose -f docker-compose.test-db.yml down -v",
    "db:check:repository": "pnpm db:seed && node scripts/db/check-repository.mjs",
    "db:check:migrations-seed": "pnpm db:migrate && pnpm db:seed && node scripts/db/check-migrations-seed.mjs",
    "db:check": "pnpm db:check:migrations-seed && pnpm db:check:repository && pnpm db:check:http",
    "db:check:http": "pnpm db:seed && node scripts/db/check-http-routes.mjs",
    "db:backup": "node scripts/db/backup.mjs",
    "db:restore": "node scripts/db/restore.mjs",
    "github:labels:sync": "node scripts/github/sync-labels.mjs",
    "github:issue:new": "node scripts/github/create-issue.mjs",
    "github:issue:status": "node scripts/github/set-issue-status.mjs",
    "github:issues:migrate-legacy": "node scripts/github/migrate-legacy-open-items.mjs",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "release:tag": "node scripts/release/create-release-tag.mjs"
  },
  "dependencies": {
    "@nuxt/ui": "latest",
    "@nuxtjs/i18n": "latest",
    "@pinia/nuxt": "latest",
    "@prisma/client": "^6.19.0",
    "@vueuse/core": "latest",
    "@vueuse/nuxt": "latest",
    "date-fns": "latest",
    "echarts": "latest",
    "pg": "^8.20.0",
    "pinia": "latest",
    "pino": "^10.3.1",
    "vue-echarts": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@nuxt/eslint": "latest",
    "@nuxt/test-utils": "latest",
    "@pinia/testing": "latest",
    "@playwright/test": "latest",
    "@vue/test-utils": "latest",
    "eslint": "latest",
    "happy-dom": "latest",
    "msw": "latest",
    "nuxt": "^4.4.5",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "vue-tsc": "latest"
  }
}
