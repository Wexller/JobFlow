{
  "name": "jobflow",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.14.4"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm prepare && vitest",
    "test:unit": "pnpm prepare && vitest run tests/unit",
    "test:nuxt": "pnpm prepare && vitest run tests/nuxt --passWithNoTests",
    "test:e2e": "pnpm build && playwright test",
    "test:ci": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:nuxt && pnpm test:e2e && pnpm build",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:seed": "node scripts/db/seed.mjs",
    "db:test:up": "node scripts/db/test-db-up.mjs",
    "db:test:down": "node scripts/db/test-db-down.mjs",
    "db:test:url": "node scripts/db/test-db-url.mjs",
    "db:test:reset": "pnpm db:test:down && pnpm db:test:up"
  },
  "dependencies": {
    "@nuxt/ui": "latest",
    "@nuxtjs/i18n": "latest",
    "@pinia/nuxt": "latest",
    "@vueuse/core": "latest",
    "@vueuse/nuxt": "latest",
    "date-fns": "latest",
    "echarts": "latest",
    "pg": "^8.20.0",
    "pinia": "latest",
    "vue-echarts": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@nuxt/eslint": "latest",
    "@nuxt/test-utils": "latest",
    "@oxc-minify/binding-darwin-arm64": "0.128.0",
    "@oxc-parser/binding-darwin-arm64": "0.128.0",
    "@oxc-transform/binding-darwin-arm64": "0.128.0",
    "@pinia/testing": "latest",
    "@playwright/test": "latest",
    "@vue/test-utils": "latest",
    "eslint": "latest",
    "happy-dom": "latest",
    "msw": "latest",
    "nuxt": "^4.4.5",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "vue-tsc": "latest"
  }
}
