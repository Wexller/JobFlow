generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("JOBFLOW_DATABASE_URL")
}

model Vacancy {
  id           String   @id
  company      String
  role         String
  status       String
  priority     String
  format       String
  source       String?
  location     String?
  level        String?
  techStack    String[] @default([]) @map("tech_stack")
  salaryMin    Decimal? @db.Decimal(12, 2) @map("salary_min")
  salaryMax    Decimal? @db.Decimal(12, 2) @map("salary_max")
  currency     String?
  matchScore   Decimal? @db.Decimal(5, 2) @map("match_score")
  appliedAt    DateTime? @db.Date @map("applied_at")
  nextActionAt DateTime? @map("next_action_at")
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @map("updated_at")
  archivedAt   DateTime? @map("archived_at")
  notes        String?

  pipelineEvents PipelineEvent[]
  interviews     Interview[]
  offer          Offer?

  @@map("vacancies")
}

model PipelineEvent {
  id            String   @id
  vacancyId     String   @map("vacancy_id")
  stage         String
  status        String
  title         String?
  occurredAt    DateTime? @map("occurred_at")
  scheduledAt   DateTime? @map("scheduled_at")
  completedAt   DateTime? @map("completed_at")
  notes         String?

  vacancy       Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  interviews    Interview[]

  @@unique([id, vacancyId], map: "idx_pipeline_events_id_vacancy")
  @@map("pipeline_events")
}

model Interview {
  id               String   @id
  vacancyId        String   @map("vacancy_id")
  pipelineEventId  String?  @map("pipeline_event_id")
  stage            String
  scheduledAt      DateTime @map("scheduled_at")
  result           String
  interviewerNames String[] @default([]) @map("interviewer_names")
  location         String?
  notes            String?

  vacancy      Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pipelineEvent PipelineEvent? @relation(fields: [pipelineEventId, vacancyId], references: [id, vacancyId], onDelete: Restrict, onUpdate: Cascade)

  @@map("interviews")
}

model Offer {
  id            String    @id
  vacancyId     String    @unique @map("vacancy_id")
  decision      String
  offeredAt     DateTime? @map("offered_at")
  decisionDueAt DateTime? @map("decision_due_at")
  salaryMin     Decimal?  @db.Decimal(12, 2) @map("salary_min")
  salaryMax     Decimal?  @db.Decimal(12, 2) @map("salary_max")
  currency      String?
  notes         String?

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("offers")
}
